<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/bg_page"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- TAB COMPLETED / CANCELLED -->
    <LinearLayout
        android:id="@+id/tabContainer"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_margin="16dp"
        android:background="@drawable/bg_tab_container"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnCompleted"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Completed"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_tab_active"/>

        <Button
            android:id="@+id/btnCancelled"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Cancelled"
            android:textColor="#8B2E2E"
            android:background="@android:color/transparent"/>

    </LinearLayout>

    <!-- FILTER TANGGAL -->
    <LinearLayout
        android:id="@+id/dateFilter"
        android:layout_below="@id/tabContainer"
        android:layout_marginHorizontal="16dp"
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:background="@drawable/bg_date_filter"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp">

        <TextView
            android:id="@+id/tvDate"
            android:text="Senin, 24 Januari 2025"
            android:textColor="#8B2E2E"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"/>

        <ImageView
            android:src="@drawable/ic_calendar"
            android:layout_width="24dp"
            android:layout_height="24dp"/>

    </LinearLayout>

    <!-- LIST HISTORY -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerHistory"
        android:layout_below="@id/dateFilter"
        android:layout_marginTop="10dp"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="10dp"/>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabDelete"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_margin="20dp"
        android:src="@drawable/ic_delete"
        android:contentDescription="Delete History"
        app:backgroundTint="#FF2E2E"/>

</RelativeLayout>
<?xml version="1.0" encoding="utf-8"?>

<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/bg_page"
    tools:context=".ui.search.SearchFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cari Menu"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="@color/primary_title"
            android:gravity="center"
            android:padding="12dp"
            android:background="@drawable/bg_menu_title"/>

        <!-- Search Box -->
        <androidx.cardview.widget.CardView
            xmlns:card_view="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            card_view:cardCornerRadius="16dp"
            card_view:cardElevation="3dp"
            card_view:cardBackgroundColor="@color/setting_card">

            <EditText
                android:id="@+id/etSearch"
                android:textColor="@color/setting_text"
                android:textColorHint="@color/setting_text"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:paddingHorizontal="16dp"
                android:hint="Cari menu bakso..."
                android:background="@android:color/transparent"/>

        </androidx.cardview.widget.CardView>

        <!-- RecyclerView -->
        <androidx.cardview.widget.CardView
            xmlns:card_view="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            card_view:cardCornerRadius="16dp"
            card_view:cardElevation="3dp"
            card_view:cardBackgroundColor="@color/setting_card">
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerViewSearchResults"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="16dp"/>
        </androidx.cardview.widget.CardView>

        <!-- Empty State -->
        <LinearLayout
            android:id="@+id/layoutEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            android:layout_marginTop="40dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔍"
                android:textSize="72sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Menu tidak ditemukan"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/setting_text"
                android:layout_marginTop="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Coba gunakan kata kunci lain"
                android:textSize="14sp"
                android:textColor="@color/text_3"
                android:layout_marginTop="6dp"/>

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
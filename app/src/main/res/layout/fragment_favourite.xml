<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@drawable/bg_page"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- RECYCLER -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerFavourite"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp"/>

    <!-- EMPTY STATE -->
    <LinearLayout
        android:id="@+id/layoutEmpty"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="20dp"
        android:visibility="gone">

        <!-- ICON -->
        <TextView
            android:text="☹"
            android:textSize="80sp"
            android:textColor="#8B2E2E"
            android:layout_height="wrap_content"
            android:layout_width="wrap_content"/>

        <!-- TEXT -->
        <TextView
            android:text="Maaf, Belum ada menu dalam favourite"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#8B2E2E"
            android:gravity="center"
            android:layout_marginTop="12dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Silahkan tambahkan menu favourite anda"
            android:textSize="14sp"
            android:textColor="#8B2E2E"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- BUTTON -->
        <Button
            android:id="@+id/btnTambah"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tambahkan Pesanan"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF2E2E"
            android:layout_marginTop="16dp"/>
    </LinearLayout>

</FrameLayout>
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Scan QRIS untuk Membayar"
        android:textStyle="bold"
        android:textSize="18sp"
        android:textColor="@color/setting_text"
        android:layout_marginBottom="16dp"/>

    <ImageView
        android:id="@+id/imgQrDummy"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:scaleType="fitCenter"
        android:background="#F0F0F0"/>

    <TextView
        android:id="@+id/tvTotalBayar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:textStyle="bold"
        android:textSize="20sp"
        android:textColor="@color/red"
        android:text="Rp 0"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="(Mode Simulasi — Bukan Pembayaran Sungguhan)"
        android:textSize="12sp"
        android:textColor="@color/setting_text"/>

    <Button
        android:id="@+id/btnKonfirmasiBayar"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="20dp"
        android:text="Simulasi Bayar Berhasil"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:backgroundTint="@color/red"/>

</LinearLayout>
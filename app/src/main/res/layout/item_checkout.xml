<?xml version="1.0" encoding="utf-8"?>
<!--item_checkout.xml-->
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/tools"
    android:layout_marginBottom="12dp"
    card_view:cardCornerRadius="16dp"
    card_view:cardElevation="4dp"
    card_view:cardBackgroundColor="@color/setting_card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/imgMenu"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:scaleType="centerCrop"
            android:src="@drawable/bakso" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tvNama"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bakso Keju"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/setting_text"/>

            <TextView
                android:id="@+id/tvAddon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Extra Keju, Sambal"
                android:textColor="@color/setting_text"
                android:alpha="0.7"
                android:layout_marginTop="4dp"/>

            <TextView
                android:id="@+id/tvQty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Jumlah : 2"
                android:textColor="@color/setting_text"
                android:alpha="0.7"
                android:layout_marginTop="4dp"/>

            <TextView
                android:id="@+id/tvTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rp 50.000"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/red"
                android:layout_marginTop="8dp"/>

            <Button
                android:id="@+id/btnEditOrder"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Edit"
                android:textColor="@android:color/white"
                android:backgroundTint="@color/red"
                android:layout_marginTop="8dp"/>

        </LinearLayout>

        <ImageView
            android:id="@+id/btnDeleteOrder"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/ic_delete"
            app:tint="@color/text_4"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>